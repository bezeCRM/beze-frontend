{
    "expo": {
        "name": "beze-frontend",
        "slug": "beze-frontend",
        "scheme": "beze",
        "icon": "./src/assets/icons/icon.png",
        "version": "1.0.0",
        "assetBundlePatterns": ["**/*"],
        "plugins": [
            "expo-font",
            "expo-web-browser",
            "expo-mail-composer",
            [
                "expo-splash-screen",
                {
                    "backgroundColor": "#FF8EB1",
                    "image": "./src/assets/icons/splash-icon.png",
                    "imageWidth": 150
                }
            ],
            "expo-secure-store"
        ],
        "platforms": ["ios", "android"],
        "ios": {
            "infoPlist": {
                "NSPhotoLibraryUsageDescription": "Нужно для выбора фото из галереи"
            }
        },
        "android": {
            "package": "com.bezefrontend.crm",
            "versionCode": 1,
            "adaptiveIcon": {
                "foregroundImage": "./src/assets/icons/icon.png",
                "backgroundColor": "#FF8EB1"
            }
        },
        "extra": {
            "eas": {
                "projectId": "eaa2b4f7-089f-41f1-a48a-4034d0d1198e"
            }
        },
        "userInterfaceStyle": "automatic"
    }
}
