{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"]
        },
        "jsx": "react-native",
        "target": "esnext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true
    },
    "include": ["src", "declarations.d.ts"]
}
